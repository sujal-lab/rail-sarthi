<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body class="text-slate-800 selection:bg-ryred-500 selection:text-white">

    <%- include('partials/navbar', { currentPage }) %>
    <%- include('partials/toast') %>

    <main>
        <section class="py-16 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="font-heading text-4xl font-black mb-10">Admin Dashboard</h2>
            <div class="grid grid-cols-1 xl:grid-cols-3 gap-10">
                <!-- Add Form -->
                <div class="col-span-1 bg-white rounded-[2rem] shadow-card border border-slate-100 p-8 sticky top-28 h-fit">
                    <h3 class="text-2xl font-heading font-black mb-6 flex items-center gap-3">
                        <div class="w-10 h-10 rounded-xl bg-ryblue-50 flex items-center justify-center text-ryblue-600"><i class="ph-bold ph-plus"></i></div>
                        Nai Train Jodein
                    </h3>
                    <form id="addTrainForm" class="space-y-4">
                        <input type="text" id="trainNo" required placeholder="Train No (e.g. 12045)"
                            class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 focus:border-ryblue-500 outline-none font-bold text-slate-700">
                        <input type="text" id="trainName" required placeholder="Train Name"
                            class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 focus:border-ryblue-500 outline-none font-bold text-slate-700">
                        <div class="grid grid-cols-2 gap-4">
                            <input type="text" id="source" required placeholder="From Station"
                                class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 focus:border-ryblue-500 outline-none font-bold text-slate-700">
                            <input type="text" id="destination" required placeholder="To Station"
                                class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 focus:border-ryblue-500 outline-none font-bold text-slate-700">
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="space-y-1">
                                <label class="text-[10px] font-bold text-slate-400 uppercase ml-2">Service Starts</label>
                                <input type="date" id="startDate" required
                                       class="w-full bg-slate-50 border border-transparent focus:border-ryblue-100 focus:bg-white p-4 rounded-2xl text-sm font-medium outline-none transition-all">
                            </div>
                            <div class="space-y-1">
                                <label class="text-[10px] font-bold text-slate-400 uppercase ml-2">Service Ends</label>
                                <input type="date" id="endDate" required
                                       class="w-full bg-slate-50 border border-transparent focus:border-ryblue-100 focus:bg-white p-4 rounded-2xl text-sm font-medium outline-none transition-all">
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="text-xs font-bold text-slate-400 uppercase">Departure</label>
                                <input type="time" id="depTime" required class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 outline-none font-bold text-slate-700">
                            </div>
                            <div>
                                <label class="text-xs font-bold text-slate-400 uppercase">Arrival</label>
                                <input type="time" id="arrTime" required class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 outline-none font-bold text-slate-700">
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <input type="number" id="totalSeats" required min="1" placeholder="Seats"
                                class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 outline-none font-bold text-slate-700">
                            <input type="number" id="price" required min="0" placeholder="Price ₹"
                                class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 outline-none font-bold text-slate-700">
                        </div>
                        <button type="submit" class="w-full bg-ryblue-900 hover:bg-slate-900 text-white font-heading font-bold text-lg py-4 rounded-xl mt-4 transition-colors">
                            Add Train
                        </button>
                    </form>
                </div>

                <!-- Train List (server-rendered) -->
                <div class="col-span-1 xl:col-span-2 bg-white rounded-[2rem] shadow-card border border-slate-100 overflow-hidden">
                    <div class="p-6 md:p-8 border-b border-slate-100 flex justify-between items-center">
                        <h3 class="text-2xl font-heading font-black">Active Trains</h3>
                        <a href="/view/admin" class="w-10 h-10 rounded-full bg-slate-50 text-slate-500 hover:text-ryblue-600 transition-colors flex items-center justify-center">
                            <i class="ph-bold ph-arrows-clockwise text-xl"></i>
                        </a>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="text-slate-400 font-heading text-xs font-bold uppercase tracking-widest border-b border-slate-100">
                                    <th class="p-6">Details</th><th class="p-6">Route & Timeline</th>
                                    <th class="p-6">Seats & Fare</th><th class="p-6 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="adminTrainsTableBody" class="divide-y divide-slate-50 text-sm font-medium">
                                <% if (trains.length === 0) { %>
                                    <tr><td colspan="4" class="p-16 text-center font-bold text-slate-400">No trains added yet.</td></tr>
                                <% } else { %>
                                    <% trains.forEach(x => { %>
                                        <tr class="hover:bg-slate-50/50 transition-colors">
                                            <td class="p-6 font-bold text-slate-800"><%= x.trainName %></td>
                                            <td class="p-6 text-slate-500"><%= x.source %> → <%= x.destination %></td>
                                            <td class="p-6 font-bold text-emerald-600">₹<%= x.price %></td>
                                            <td class="p-6 text-right space-x-2">
                                                <button onclick="openEditModal('<%= x._id %>')"
                                                    class="text-xs font-bold text-ryblue-600 hover:text-ryblue-700 bg-ryblue-50 hover:bg-ryblue-100 px-4 py-2 rounded-xl transition-colors">
                                                    Edit
                                                </button>
                                                <button onclick="deleteTrain('<%= x._id %>')"
                                                    class="text-xs font-bold text-ryred-500 hover:text-ryred-600 bg-ryred-50 hover:bg-ryred-100 px-4 py-2 rounded-xl transition-colors">
                                                    Delete
                                                </button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Modal -->
            <div id="trainModal" class="fixed inset-0 bg-slate-900/40 hidden z-50 flex items-center justify-center backdrop-blur-sm">
                <div class="bg-white rounded-[2rem] shadow-2xl w-full max-w-md p-2 m-4">
                    <div class="p-4 border-b border-slate-100 flex justify-between items-center">
                        <h3 class="font-heading font-black text-xl text-ryblue-900">Train Details</h3>
                        <button onclick="document.getElementById('trainModal').classList.add('hidden')" class="w-8 h-8 rounded-full bg-slate-50 text-slate-400 hover:text-ryred-500 transition-colors">
                            <i class="ph-bold ph-x"></i>
                        </button>
                    </div>
                    <div id="modalContent" class="p-6"></div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
    <%- include('partials/chat') %>

    <!-- Admin page JS: add train, edit, delete (client-side) -->
    <script id="trains-data" type="application/json"><%- JSON.stringify(trains || []) %></script>
    <script>
    const allTrainsData = JSON.parse(document.getElementById('trains-data').textContent);

    // $ is already defined globally by chat.ejs partial

    /* Add Train Form */
    $('addTrainForm').onsubmit = async (e) => {
        e.preventDefault();
        const payload = {
            trainNo:      $('trainNo').value.trim(),
            trainName:    $('trainName').value.trim(),
            source:       $('source').value.trim(),
            destination:  $('destination').value.trim(),
            dep:          $('depTime').value,
            arr:          $('arrTime').value,
            startDate:    $('startDate').value,
            endDate:      $('endDate').value,
            totalSeats:   parseInt($('totalSeats').value),
            price:        parseInt($('price').value)
        };
        try {
            const r = await fetch('/trains', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            if (r.ok) {
                showToast('Train added to schedule!', 'success');
                $('addTrainForm').reset();
                setTimeout(() => window.location.reload(), 500);
            } else {
                const err = await r.json().catch(() => ({}));
                showToast(err.message || 'Error adding train.', 'error');
            }
        } catch {
            showToast('Server offline', 'error');
        }
    };

    /* Delete Train */
    window.deleteTrain = async (id) => {
        if (confirm('Delete this train?')) {
            try {
                const r = await fetch(`/trains/${id}`, { method: 'DELETE' });
                if (r.ok) {
                    showToast('Train deleted successfully!', 'success');
                    setTimeout(() => window.location.reload(), 500);
                } else {
                    showToast('Could not delete train.', 'error');
                }
            } catch {
                showToast('Server offline', 'error');
            }
        }
    };

    /* Edit Train Modal */
    window.openEditModal = (id) => {
        const train = allTrainsData.find(t => t._id === id);
        if (!train) return showToast('Train not found', 'error');

        $('trainModal').classList.remove('hidden');
        $('modalContent').innerHTML = `
            <form id="editTrainForm" class="space-y-4">
                <input type="hidden" id="editTrainId" value="${train._id}">
                <input type="text" id="editTrainNo" required value="${train.trainNo}" placeholder="Train No"
                    class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 focus:border-ryblue-500 outline-none font-bold text-slate-700">
                <input type="text" id="editTrainName" required value="${train.trainName}" placeholder="Train Name"
                    class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 focus:border-ryblue-500 outline-none font-bold text-slate-700">
                <div class="grid grid-cols-2 gap-4">
                    <input type="text" id="editSource" required value="${train.source}" placeholder="From"
                        class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 focus:border-ryblue-500 outline-none font-bold text-slate-700">
                    <input type="text" id="editDestination" required value="${train.destination}" placeholder="To"
                        class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 focus:border-ryblue-500 outline-none font-bold text-slate-700">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-[10px] font-bold text-slate-400 uppercase ml-2">Service Starts</label>
                        <input type="date" id="editStartDate" value="${train.startDate || ''}" required
                               class="w-full bg-slate-50 border border-transparent focus:border-ryblue-100 focus:bg-white p-3.5 rounded-xl text-sm font-medium outline-none transition-all">
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] font-bold text-slate-400 uppercase ml-2">Service Ends</label>
                        <input type="date" id="editEndDate" value="${train.endDate || ''}" required
                               class="w-full bg-slate-50 border border-transparent focus:border-ryblue-100 focus:bg-white p-3.5 rounded-xl text-sm font-medium outline-none transition-all">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-xs font-bold text-slate-400 uppercase">Departure</label>
                        <input type="time" id="editDepTime" value="${train.dep}" required class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 outline-none font-bold text-slate-700">
                    </div>
                    <div>
                        <label class="text-xs font-bold text-slate-400 uppercase">Arrival</label>
                        <input type="time" id="editArrTime" value="${train.arr}" required class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 outline-none font-bold text-slate-700">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <input type="number" id="editTotalSeats" required min="1" value="${train.totalSeats}" placeholder="Seats"
                        class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 outline-none font-bold text-slate-700">
                    <input type="number" id="editPrice" required min="0" value="${train.price}" placeholder="Price ₹"
                        class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl p-3.5 outline-none font-bold text-slate-700">
                </div>
                <button type="submit" class="w-full bg-ryblue-600 hover:bg-ryblue-700 text-white font-heading font-bold text-lg py-4 rounded-xl mt-4 transition-colors">
                    Save Changes
                </button>
            </form>
        `;

        $('editTrainForm').onsubmit = async (e) => {
            e.preventDefault();
            const payload = {
                trainNo:      $('editTrainNo').value.trim(),
                trainName:    $('editTrainName').value.trim(),
                source:       $('editSource').value.trim(),
                destination:  $('editDestination').value.trim(),
                dep:          $('editDepTime').value,
                arr:          $('editArrTime').value,
                startDate:    $('editStartDate').value,
                endDate:      $('editEndDate').value,
                totalSeats:   parseInt($('editTotalSeats').value),
                price:        parseInt($('editPrice').value)
            };
            try {
                const r = await fetch(`/trains/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (r.ok) {
                    showToast('Train updated successfully!', 'success');
                    $('trainModal').classList.add('hidden');
                    setTimeout(() => window.location.reload(), 500);
                } else {
                    const err = await r.json().catch(() => ({}));
                    showToast(err.message || 'Error updating train.', 'error');
                }
            } catch {
                showToast('Server offline', 'error');
            }
        };
    };
    </script>

</body>
</html>
