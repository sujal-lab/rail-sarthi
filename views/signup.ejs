<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body class="bg-slate-50 text-slate-800 font-sans selection:bg-ryred-500 selection:text-white min-h-screen flex flex-col">

    <%- include('partials/navbar', { currentPage }) %>

    <main class="flex-grow flex items-center justify-center p-4">
        <div class="bg-white p-8 rounded-3xl shadow-xl w-full max-w-md border border-slate-100 my-10">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-heading font-black text-slate-800">Join Rail-Sarthi</h1>
                <p class="text-slate-500 font-medium mt-2">Create an account to manage your bookings.</p>
            </div>

            <form action="/auth/signup" method="POST" class="space-y-5">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Full Name</label>
                    <input type="text" name="name" required placeholder="Enter your name"
                        class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:border-ryblue-500 focus:ring-2 focus:ring-ryblue-100 outline-none transition-all">
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Email</label>
                    <input type="email" name="email" required placeholder="Enter your email"
                        class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:border-ryblue-500 focus:ring-2 focus:ring-ryblue-100 outline-none transition-all">
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Password</label>
                    <input type="password" name="password" required placeholder="Create a password"
                        class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:border-ryblue-500 focus:ring-2 focus:ring-ryblue-100 outline-none transition-all">
                </div>
                
                <button type="submit" class="w-full bg-ryred-500 hover:bg-ryred-600 text-white font-bold py-3 rounded-xl transition-all shadow-md mt-4">
                    Sign Up
                </button>
            </form>

            <div class="mt-6 text-center text-sm font-medium text-slate-500">
                Already have an account? <a href="/view/login" class="text-ryblue-600 hover:text-ryblue-700 font-bold">Log In</a>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
