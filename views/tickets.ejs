<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body class="text-slate-800 selection:bg-ryred-500 selection:text-white">

    <%- include('partials/navbar', { currentPage }) %>
    <%- include('partials/toast') %>

    <main>
        <section class="py-16 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

            <!-- Page header -->
            <div class="mb-10">
                <h2 class="font-heading text-4xl font-black">Train Tickets</h2>
                <p class="text-slate-500 font-medium mt-1">Find trains, compare options, and book in seconds.</p>
            </div>

            <!-- ── TICKET SEARCH FORM ── -->
            <div id="ticketSearchSection">
                <form action="/view/tickets" method="GET" class="bg-white/90 backdrop-blur-xl rounded-[2rem] shadow-glass border border-white/60 p-8 mb-10">
                    <h3 class="font-heading font-black text-xl text-slate-800 mb-6 flex items-center gap-2">
                        <i class="ph-fill ph-magnifying-glass text-ryblue-600"></i> Search Trains
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                        <div>
                            <label class="block text-xs font-bold font-heading text-ryblue-600 uppercase tracking-widest mb-2">From</label>
                            <div class="relative">
                                <i class="ph-fill ph-map-pin absolute left-4 top-4 text-slate-400 text-xl"></i>
                                <input type="text" name="from" required placeholder="e.g. Delhi" value="<%= typeof from !== 'undefined' && from ? from : '' %>"
                                    class="w-full pl-12 pr-4 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl text-slate-700 font-bold focus:border-ryblue-500 outline-none transition-colors">
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-bold font-heading text-ryblue-600 uppercase tracking-widest mb-2">To</label>
                            <div class="relative">
                                <i class="ph-fill ph-navigation-arrow absolute left-4 top-4 text-slate-400 text-xl"></i>
                                <input type="text" name="to" required placeholder="e.g. Mumbai" value="<%= typeof to !== 'undefined' && to ? to : '' %>"
                                    class="w-full pl-12 pr-4 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl text-slate-700 font-bold focus:border-ryblue-500 outline-none transition-colors">
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-bold font-heading text-ryblue-600 uppercase tracking-widest mb-2">Journey Date</label>
                            <div class="relative">
                                <i class="ph-fill ph-calendar-blank absolute left-4 top-4 text-slate-400 text-xl"></i>
                                <input type="date" name="date" id="ticketDate" required value="<%= typeof date !== 'undefined' && date ? date : '' %>"
                                    class="w-full pl-12 pr-4 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl text-slate-700 font-bold focus:border-ryblue-500 outline-none transition-colors">
                            </div>
                        </div>
                    </div>
                    <button type="submit"
                        class="bg-ryred-500 hover:bg-ryred-600 text-white font-heading font-bold text-base px-10 py-4 rounded-2xl transition-all shadow-[0_8px_20px_-6px_rgba(214,52,71,0.5)] hover:-translate-y-0.5 flex items-center gap-2">
                        Search Trains <i class="ph-bold ph-magnifying-glass"></i>
                    </button>
                </form>

                <!-- ── TRAIN RESULTS (server-rendered) ── -->
                <div id="ticketResults">
                    <% if (typeof trains !== 'undefined' && trains !== null) { %>
                        <% if (trains.length === 0) { %>
                            <div class="text-center py-16 bg-white rounded-[2rem] border border-slate-100 shadow-sm">
                                <div class="w-20 h-20 rounded-full bg-slate-50 flex items-center justify-center mx-auto mb-4">
                                    <i class="ph-bold ph-train text-4xl text-slate-300"></i>
                                </div>
                                <p class="font-heading font-black text-xl text-slate-500">No trains found</p>
                                <p class="text-sm text-slate-400 mt-2 font-medium">Try different cities or check the spelling.</p>
                            </div>
                        <% } else { %>
                            <div class="flex items-center justify-between mb-5">
                                <div>
                                    <span class="font-heading font-black text-lg text-slate-800">
                                        <%= trains.length %> Train<%= trains.length > 1 ? 's' : '' %> Found
                                    </span>
                                    <span class="ml-3 text-sm text-slate-400 font-medium">
                                        <%= from %> → <%= to %> &nbsp;·&nbsp; <%= date || '' %>
                                    </span>
                                </div>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                <% trains.forEach(t => { %>
                                    <%
                                        // Calculate duration
                                        let durationBadge = '';
                                        if (t.dep && t.arr) {
                                            const [dh, dm] = t.dep.split(':').map(Number);
                                            const [ah, am] = t.arr.split(':').map(Number);
                                            let mins = (ah * 60 + am) - (dh * 60 + dm);
                                            if (mins < 0) mins += 1440;
                                            const hrs = Math.floor(mins / 60);
                                            const rem = mins % 60;
                                            durationBadge = `${hrs}h ${rem}m`;
                                        }

                                        // Format time
                                        function fmtTime(timeStr) {
                                            if (!timeStr) return '--:--';
                                            const [h, m] = timeStr.split(':');
                                            let hours = parseInt(h);
                                            const ampm = hours >= 12 ? 'PM' : 'AM';
                                            hours = hours % 12 || 12;
                                            return `${hours}:${m} ${ampm}`;
                                        }

                                        const seatsColor = t.totalSeats > 50 ? 'text-emerald-600' :
                                                           t.totalSeats > 20 ? 'text-amber-500' : 'text-ryred-500';
                                    %>
                                    <div class="bg-white border border-slate-100 rounded-[1.5rem] p-6 hover:shadow-float transition-all duration-300 group">
                                        <!-- Train header -->
                                        <div class="flex justify-between items-start mb-5">
                                            <div>
                                                <div class="font-heading font-black text-lg text-slate-800"><%= t.trainName %></div>
                                                <div class="text-xs text-slate-400 font-bold mt-0.5"><%= t.trainNo %></div>
                                            </div>
                                            <div class="text-right">
                                                <div class="font-heading font-black text-2xl text-emerald-600">₹<%= t.price %></div>
                                                <div class="text-xs <%= seatsColor %> font-bold"><%= t.totalSeats %> seats avail.</div>
                                            </div>
                                        </div>

                                        <!-- Route timeline -->
                                        <div class="flex items-center gap-3 mb-6">
                                            <div class="text-center">
                                                <div class="font-heading font-black text-xl text-slate-800"><%= fmtTime(t.dep) %></div>
                                                <div class="text-xs text-slate-400 font-medium mt-0.5"><%= t.source %></div>
                                            </div>
                                            <div class="flex-1 flex flex-col items-center gap-1">
                                                <% if (durationBadge) { %>
                                                    <span class="text-xs bg-slate-100 text-slate-500 px-2 py-0.5 rounded-full font-bold"><%= durationBadge %></span>
                                                <% } %>
                                                <div class="w-full flex items-center gap-1">
                                                    <div class="w-2 h-2 rounded-full bg-ryblue-600 shrink-0"></div>
                                                    <div class="flex-1 h-0.5 bg-gradient-to-r from-ryblue-200 to-ryred-200 relative">
                                                        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-3 h-3 rounded-full border-2 border-ryblue-300 bg-white"></div>
                                                    </div>
                                                    <div class="w-2 h-2 rounded-full bg-ryred-500 shrink-0"></div>
                                                </div>
                                            </div>
                                            <div class="text-center">
                                                <div class="font-heading font-black text-xl text-slate-800"><%= fmtTime(t.arr) %></div>
                                                <div class="text-xs text-slate-400 font-medium mt-0.5"><%= t.destination %></div>
                                            </div>
                                        </div>

                                        <!-- CTA -->
                                        <button
                                            onclick="selectTrain('<%= t._id %>')"
                                            class="w-full bg-ryblue-900 hover:bg-ryred-500 text-white font-heading font-bold py-3.5 rounded-2xl transition-all duration-300 group-hover:shadow-md flex items-center justify-center gap-2">
                                            Select &amp; Book
                                            <i class="ph-bold ph-arrow-right group-hover:translate-x-1 transition-transform"></i>
                                        </button>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    <% } %>
                </div>
            </div>

            <!-- ── PASSENGER BOOKING FORM (hidden until train selected) ── -->
            <div id="ticketBookingSection" class="hidden">

                <!-- Back button -->
                <button type="button" onclick="showTicketResults()"
                    class="mb-6 text-ryblue-600 font-bold text-sm flex items-center gap-2 hover:text-ryblue-800 transition group">
                    <span class="w-8 h-8 rounded-full bg-ryblue-50 group-hover:bg-ryblue-100 flex items-center justify-center transition">
                        <i class="ph-bold ph-arrow-left"></i>
                    </span>
                    Back to Train Results
                </button>

                <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">

                    <!-- Selected train summary card -->
                    <div class="lg:col-span-2">
                        <div class="bg-white rounded-[2rem] shadow-card border border-slate-100 p-6 sticky top-28">
                            <div class="flex items-center gap-2 mb-5">
                                <div class="w-8 h-8 rounded-lg bg-ryblue-50 flex items-center justify-center">
                                    <i class="ph-bold ph-train text-ryblue-600"></i>
                                </div>
                                <span class="font-heading font-black text-base text-ryblue-900">Selected Train</span>
                            </div>
                            <div id="selectedTrainSummary" class="space-y-4">
                                <!-- Injected by JS -->
                            </div>
                        </div>
                    </div>

                    <!-- Passenger details form -->
                    <div class="lg:col-span-3">
                        <div class="bg-white rounded-[2rem] shadow-card border border-slate-100 p-8">
                            <h3 class="font-heading font-black text-2xl text-slate-800 mb-2">Passenger Details</h3>
                            <p class="text-slate-500 text-sm font-medium mb-8">Enter traveller information to complete your booking.</p>

                            <form id="ticketBookingForm" class="space-y-6">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="md:col-span-2">
                                        <label class="block text-xs font-bold font-heading text-ryblue-600 uppercase tracking-widest mb-2">Passenger Name</label>
                                        <div class="relative">
                                            <i class="ph-fill ph-user absolute left-4 top-4 text-slate-400 text-xl"></i>
                                            <input type="text" id="passengerName" required placeholder="Full Name"
                                                class="w-full pl-12 pr-4 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl text-slate-700 font-bold focus:border-ryblue-500 outline-none transition-colors">
                                        </div>
                                    </div>
                                    <div>
                                        <label class="block text-xs font-bold font-heading text-ryblue-600 uppercase tracking-widest mb-2">Age</label>
                                        <input type="number" id="passengerAge" required placeholder="Age" min="1" max="120"
                                            class="w-full px-4 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl text-slate-700 font-bold focus:border-ryblue-500 outline-none transition-colors">
                                    </div>
                                </div>

                                <!-- Price summary -->
                                <div class="bg-slate-50 rounded-2xl p-5 border border-slate-100">
                                    <div class="flex justify-between items-center text-sm font-medium text-slate-500 mb-2">
                                        <span>Base Fare</span>
                                        <span id="fareDisplay" class="font-bold text-slate-700">₹—</span>
                                    </div>
                                    <div class="flex justify-between items-center text-sm font-medium text-slate-500 mb-3">
                                        <span>Service Fee</span>
                                        <span class="font-bold text-slate-700">₹0</span>
                                    </div>
                                    <div class="border-t border-slate-200 pt-3 flex justify-between items-center">
                                        <span class="font-heading font-black text-base text-slate-800">Total Payable</span>
                                        <span id="totalFareDisplay" class="font-heading font-black text-xl text-emerald-600">₹—</span>
                                    </div>
                                </div>

                                <button type="submit"
                                    class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-heading font-bold text-lg py-5 rounded-2xl transition-all shadow-[0_8px_20px_-6px_rgba(16,185,129,0.5)] hover:-translate-y-1 flex items-center justify-center gap-2">
                                    <i class="ph-bold ph-lock-key text-xl"></i>
                                    Confirm &amp; Book Securely
                                </button>

                                <p class="text-center text-xs text-slate-400 font-medium flex items-center justify-center gap-1">
                                    <i class="ph-fill ph-shield-check text-emerald-500 text-base"></i>
                                    256-bit encrypted &amp; 100% secure booking
                                </p>
                            </form>
                        </div>
                    </div>

                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
    <%- include('partials/chat') %>

    <!-- Tickets page JS: booking form + selectTrain logic (client-side) -->
    <script id="trains-data" type="application/json"><%- JSON.stringify(trains || []) %></script>
    <script>
    const allTrainsData = JSON.parse(document.getElementById('trains-data').textContent);
    const searchDate = '<%= typeof date !== "undefined" && date ? date : "" %>';

    /* Booking state */
    let ticketState = {
        date: searchDate || null,
        trainId: null,
        trainInfo: null
    };

    const formatTime = (timeStr) => {
        if (!timeStr) return '--:--';
        const [h, m] = timeStr.split(':');
        let hours = parseInt(h);
        const ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12 || 12;
        return `${hours}:${m} ${ampm}`;
    };

    const showTicketResults = () => {
        document.getElementById('ticketSearchSection').classList.remove('hidden');
        document.getElementById('ticketBookingSection').classList.add('hidden');
        document.getElementById('ticketResults').scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    const showBookingForm = () => {
        document.getElementById('ticketBookingSection').classList.remove('hidden');
        document.getElementById('ticketSearchSection').classList.add('hidden');
        document.getElementById('ticketBookingSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    /* User clicks "Select & Book" on a train card */
    window.selectTrain = (id) => {
        ticketState.trainId = id;
        const train = allTrainsData.find(t => t._id === id);
        if (!train) { showToast('Train not found. Please refresh.', 'error'); return; }

        ticketState.trainInfo = train;

        document.getElementById('selectedTrainSummary').innerHTML = `
            <div class="text-center pb-4 border-b border-slate-100">
                <div class="font-heading font-black text-xl text-slate-800">${train.trainName}</div>
                <div class="text-xs text-slate-400 font-bold mt-1">${train.trainNo}</div>
            </div>
            <div class="flex justify-between items-center pt-2">
                <div class="text-center">
                    <div class="font-black text-lg text-slate-800">${formatTime(train.dep)}</div>
                    <div class="text-xs text-slate-400 font-medium">${train.source}</div>
                </div>
                <div class="flex-1 px-3">
                    <div class="w-full h-0.5 bg-gradient-to-r from-ryblue-200 to-ryred-200 relative">
                        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full border-2 border-ryblue-300 bg-white"></div>
                    </div>
                </div>
                <div class="text-center">
                    <div class="font-black text-lg text-slate-800">${formatTime(train.arr)}</div>
                    <div class="text-xs text-slate-400 font-medium">${train.destination}</div>
                </div>
            </div>
            <div class="bg-emerald-50 border border-emerald-100 rounded-2xl p-4 text-center">
                <div class="text-xs font-bold text-emerald-700 uppercase tracking-widest mb-1">Total Fare</div>
                <div class="font-heading font-black text-3xl text-emerald-600">₹${train.price}</div>
                <div class="text-xs text-emerald-600 font-medium mt-1">per passenger</div>
            </div>
            <div class="text-xs text-slate-400 font-medium space-y-1.5 border-t border-slate-100 pt-3">
                <div class="flex justify-between">
                    <span>Date</span>
                    <span class="font-bold text-slate-600">${ticketState.date || 'Not set'}</span>
                </div>
                <div class="flex justify-between">
                    <span>Available Seats</span>
                    <span class="font-bold text-slate-600">${train.totalSeats}</span>
                </div>
            </div>
        `;

        document.getElementById('fareDisplay').textContent = `₹${train.price}`;
        document.getElementById('totalFareDisplay').textContent = `₹${train.price}`;
        document.getElementById('passengerName').value = '';
        document.getElementById('passengerAge').value = '';

        showBookingForm();
    };

    /* Confirm booking via API */
    document.getElementById('ticketBookingForm').onsubmit = async (e) => {
        e.preventDefault();

        if (!ticketState.trainId) {
            showToast('Please select a train first.', 'error');
            return;
        }

        const payload = {
            trainId:       ticketState.trainId,
            passengerName: document.getElementById('passengerName').value.trim(),
            age:           parseInt(document.getElementById('passengerAge').value),
            date:          ticketState.date
        };

        const submitBtn = document.querySelector('#ticketBookingForm button[type="submit"]');
        const originalText = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = `<i class="ph-bold ph-circle-notch animate-spin text-xl"></i> Booking...`;

        try {
            const r = await fetch('/bookings', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            if (r.ok) {
                showToast('🎉 Booking confirmed! Check My Bookings.', 'success');
                ticketState = { date: searchDate || null, trainId: null, trainInfo: null };
                document.getElementById('ticketBookingForm').reset();
                showTicketResults();
            } else {
                const err = await r.json().catch(() => ({}));
                showToast(err.message || 'Booking failed. Please try again.', 'error');
            }
        } catch {
            showToast('Server offline', 'error');
        }

        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
    };

    /* Set date defaults */
    window.addEventListener('DOMContentLoaded', () => {
        const today = new Date().toISOString().split('T')[0];
        const dateInput = document.getElementById('ticketDate');
        if (dateInput) {
            dateInput.min = today;
            if (!dateInput.value) dateInput.value = today;
        }
    });
    </script>

</body>
</html>
